{
  "name": "bohra-datepicker",
  "version": "0.1.0",
  "description": "A Hijri date picker for the Dawoodi Bohra Fatimi calendar — supports React and vanilla JS/HTML",
  "keywords": [
    "dawoodi bohra",
    "fatimi",
    "hijri",
    "datepicker",
    "islamic calendar",
    "bohra calendar"
  ],
  "author": "Burhanuddin Nasikwala",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./vanilla": {
      "import": "./dist/vanilla/index.js",
      "require": "./dist/vanilla/index.cjs"
    }
  },
  "main": "./dist/core/index.cjs",
  "module": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ben-Benston/bohra-datepicker.git"
  },
  "bugs": {
    "url": "https://github.com/Ben-Benston/bohra-datepicker/issues"
  },
  "homepage": "https://github.com/Ben-Benston/bohra-datepicker#readme"
}